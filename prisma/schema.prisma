// Prisma Schema — webtoonkit
// Firebase/Firestore 대신 PostgreSQL(Supabase/Neon) 사용 시 이 스키마로 교체

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  pending_seller
  seller
  admin
}

enum ApplicationStatus {
  pending
  approved
  rejected
}

model User {
  id               String               @id @default(cuid())
  email            String               @unique
  name             String               // 본인인증으로 고정
  phone            String               // 본인인증으로 고정
  passwordHash     String
  role             UserRole             @default(user)
  marketingAgreed  Boolean              @default(false)
  createdAt        DateTime             @default(now())

  application      PartnerApplication?
  assets           Asset[]
}

model PartnerApplication {
  id           String            @id @default(cuid())
  uid          String            @unique
  user         User              @relation(fields: [uid], references: [id])
  contact      String
  portfolioUrl String
  intro        String?
  status       ApplicationStatus @default(pending)
  createdAt    DateTime          @default(now())
  reviewedAt   DateTime?
}

model Asset {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String
  price       Int      @default(0)  // 0 = 무료
  formats     String[] // ["SKP", "Blend", "FBX"]
  fileUrl     String
  thumbnailUrl String?
  isPublished Boolean  @default(false)
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  createdAt   DateTime @default(now())
}
